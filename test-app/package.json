{
	"name": "test-app",
	"version": "0.0.1",
	"main": "dist/index.js",
	"scripts": {
		"build": "tsc",
		"watch": "tsc -w",
		"dev": "nodemon"
	},
	"author": "Dimitri Lilov",
	"license": "MIT",
	"type": "module",
	"dependencies": {
		"@ion/core": "^0.0.1",
		"@ion/http": "^0.0.1",
		"@ion/ws": "^0.0.1"
	},
	"devDependencies": {
		"nodemon": "^3.1.14"
	},
	"nodemonConfig": {
		"watch": [
			"src",
			"../core/lib",
			"../http/lib",
			"../ws/lib"
		],
		"ext": "js,jsx,ts,tsx,json",
		"exec": "npm run build && node ."
	}
}