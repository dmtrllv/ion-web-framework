{
	"compilerOptions": {
		"rootDir": "./src",
		"outDir": "./lib",
		"module": "nodenext",
		"target": "esnext",
		"allowSyntheticDefaultImports": true,
		"declaration": true,
		"declarationDir": "./types",
		"emitDecoratorMetadata": true,
		"experimentalDecorators": true,
		"stripInternal": true,
		"inlineSourceMap": true,
		"types": [
			"node"
		],
		"composite": true,
	},
	"extends": "@tsconfig/strictest/tsconfig.json",
	"references": [
		{
			"path": "../core",
		}
	]
}